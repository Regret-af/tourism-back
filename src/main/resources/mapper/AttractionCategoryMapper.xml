<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.AttractionCategoryMapper">

    <select id="selectEnabledCategories" resultType="com.af.tourism.pojo.entity.AttractionCategory">
        SELECT id,
               name,
               code,
               sort_order,
               status,
               created_at,
               updated_at
        FROM attraction_categories
        WHERE status = 1
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>

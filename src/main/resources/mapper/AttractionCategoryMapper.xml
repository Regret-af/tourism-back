<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.AttractionCategoryMapper">

    <resultMap id="AdminAttractionCategoryMap" type="com.af.tourism.pojo.vo.admin.AttractionCategoryForAdminVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="AdminAttractionCategoryStatsMap" type="com.af.tourism.pojo.vo.admin.AttractionCategoryStatsForAdminVO">
        <id property="categoryId" column="category_id"/>
        <result property="attractionCount" column="attraction_count"/>
    </resultMap>

    <select id="selectEnabledCategories" resultType="com.af.tourism.pojo.entity.AttractionCategory">
        SELECT id,
               name,
               code,
               sort_order,
               status,
               created_at,
               updated_at
        FROM attraction_categories
        WHERE status = 1
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectAdminCategoryList" resultMap="AdminAttractionCategoryMap">
        SELECT id,
               name,
               code,
               sort_order,
               status,
               created_at,
               updated_at
        FROM attraction_categories
        <where>
            <if test="queryDTO.keyword != null and queryDTO.keyword != ''">
                AND (
                    name LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR code LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                )
            </if>
            <if test="queryDTO.status != null">
                AND status = #{queryDTO.status}
            </if>
        </where>
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectAttractionStatsByCategoryIds" resultMap="AdminAttractionCategoryStatsMap">
        SELECT category_id,
               COUNT(1) AS attraction_count
        FROM attractions
        WHERE category_id IN
        <foreach collection="categoryIds" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
        GROUP BY category_id
    </select>

</mapper>

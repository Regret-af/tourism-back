<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.AttractionMapper">

    <resultMap id="AttractionCardMap" type="com.af.tourism.pojo.vo.app.AttractionCardVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="location_text" property="locationText"/>
        <result column="view_count" property="viewCount"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="created_at" property="createdAt"/>
        <association property="category" javaType="com.af.tourism.pojo.vo.app.AttractionCategorySimpleVO">
            <id column="category_id" property="id"/>
            <result column="category_name" property="name"/>
            <result column="category_code" property="code"/>
        </association>
    </resultMap>

    <resultMap id="AttractionDetailMap" type="com.af.tourism.pojo.vo.app.AttractionDetailVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="summary" property="summary"/>
        <result column="description" property="description"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="location_text" property="locationText"/>
        <result column="view_count" property="viewCount"/>
        <result column="sourceSynced_at" property="sourceSyncedAt"/>
        <result column="address_detail" property="addressDetail"/>
        <result column="telephone" property="telephone"/>
        <result column="opening_hours" property="openingHours"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="category" javaType="com.af.tourism.pojo.vo.app.AttractionCategorySimpleVO">
            <id column="category_id" property="id"/>
            <result column="category_name" property="name"/>
            <result column="category_code" property="code"/>
        </association>
    </resultMap>

    <resultMap id="AdminAttractionMap" type="com.af.tourism.pojo.vo.admin.AttractionForAdminVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="location_text" property="locationText"/>
        <result column="address_detail" property="addressDetail"/>
        <result column="telephone" property="telephone"/>
        <result column="opening_hours" property="openingHours"/>
        <result column="status" property="status"/>
        <result column="view_count" property="viewCount"/>
        <result column="sourceSynced_at" property="sourceSyncedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="category" javaType="com.af.tourism.pojo.vo.app.AttractionCategorySimpleVO">
            <id column="category_id" property="id"/>
            <result column="category_name" property="name"/>
            <result column="category_code" property="code"/>
        </association>
    </resultMap>

    <resultMap id="AdminAttractionDetailMap" type="com.af.tourism.pojo.vo.admin.AttractionDetailForAdminVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="summary" property="summary"/>
        <result column="description" property="description"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="location_text" property="locationText"/>
        <result column="address_detail" property="addressDetail"/>
        <result column="telephone" property="telephone"/>
        <result column="opening_hours" property="openingHours"/>
        <result column="baiduUid" property="baiduUid"/>
        <result column="sourceSynced_at" property="sourceSyncedAt"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="status" property="status"/>
        <result column="view_count" property="viewCount"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="category" javaType="com.af.tourism.pojo.vo.app.AttractionCategorySimpleVO">
            <id column="category_id" property="id"/>
            <result column="category_name" property="name"/>
            <result column="category_code" property="code"/>
        </association>
    </resultMap>

    <select id="selectAttractions" resultMap="AttractionCardMap">
        SELECT a.id,
               a.name,
               a.summary,
               a.cover_url,
               a.location_text,
               a.view_count,
               a.longitude,
               a.latitude,
               a.created_at,
               c.id AS category_id,
               c.name AS category_name,
               c.code AS category_code
        FROM attractions a
                 INNER JOIN attraction_categories c ON a.category_id = c.id
        <where>
            a.status = 1
            AND c.status = 1
            <if test="queryDTO.keyword != null and queryDTO.keyword != ''">
                AND (
                    a.name LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR a.summary LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                )
            </if>
            <if test="queryDTO.categoryId != null">
                AND a.category_id = #{queryDTO.categoryId}
            </if>
        </where>
        <choose>
            <when test="queryDTO.sortCode == 'hot'">
                ORDER BY a.view_count DESC, a.created_at DESC, a.id DESC
            </when>
            <otherwise>
                ORDER BY a.created_at DESC, a.id DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectAttractionDetail" resultMap="AttractionDetailMap">
        SELECT a.id,
               a.name,
               a.summary,
               a.description,
               a.cover_url,
               a.location_text,
               a.view_count,
               a.sourceSynced_at,
               a.address_detail,
               a.telephone,
               a.opening_hours,
               a.longitude,
               a.latitude,
               a.created_at,
               a.updated_at,
               c.id AS category_id,
               c.name AS category_name,
               c.code AS category_code
        FROM attractions a
                 INNER JOIN attraction_categories c ON a.category_id = c.id
        WHERE a.id = #{attractionId}
          AND a.status = 1
          AND c.status = 1
        LIMIT 1
    </select>

    <select id="selectAdminAttractions" resultMap="AdminAttractionMap">
        SELECT a.id,
               a.name,
               a.summary,
               a.cover_url,
               a.location_text,
               a.address_detail,
               a.telephone,
               a.opening_hours,
               a.status,
               a.view_count,
               a.sourceSynced_at,
               a.created_at,
               a.updated_at,
               c.id AS category_id,
               c.name AS category_name,
               c.code AS category_code
        FROM attractions a
                 LEFT JOIN attraction_categories c ON a.category_id = c.id
        <where>
            <if test="queryDTO.keyword != null and queryDTO.keyword != ''">
                AND (
                    a.name LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR a.summary LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR a.location_text LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR a.address_detail LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                )
            </if>
            <if test="queryDTO.categoryId != null">
                AND a.category_id = #{queryDTO.categoryId}
            </if>
            <if test="queryDTO.status != null">
                AND a.status = #{queryDTO.status.value}
            </if>
            <if test="queryDTO.createdStart != null">
                AND a.created_at &gt;= #{queryDTO.createdStart}
            </if>
            <if test="queryDTO.createdEnd != null">
                AND a.created_at &lt; DATE_ADD(#{queryDTO.createdEnd}, INTERVAL 1 DAY)
            </if>
        </where>
        ORDER BY a.created_at DESC, a.id DESC
    </select>

    <select id="selectAdminAttractionDetail" resultMap="AdminAttractionDetailMap">
        SELECT a.id,
               a.name,
               a.summary,
               a.description,
               a.cover_url,
               a.location_text,
               a.address_detail,
               a.telephone,
               a.opening_hours,
               a.baiduUid,
               a.sourceSynced_at,
               a.longitude,
               a.latitude,
               a.status,
               a.view_count,
               a.created_at,
               a.updated_at,
               c.id AS category_id,
               c.name AS category_name,
               c.code AS category_code
        FROM attractions a
                 LEFT JOIN attraction_categories c ON a.category_id = c.id
        WHERE a.id = #{attractionId}
        LIMIT 1
    </select>

</mapper>

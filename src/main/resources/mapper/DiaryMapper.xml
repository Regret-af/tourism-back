<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.DiaryMapper">

    <resultMap id="AdminDiaryListMap" type="com.af.tourism.pojo.vo.admin.DiaryForAdminVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="status" property="status"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="content_type_name" property="contentType"/>
        <result column="visibility" property="visibility"/>
        <result column="is_top" property="isTop"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="published_at" property="publishedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.admin.DiaryAuthorForAdminVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <resultMap id="AdminDiaryDetailMap" type="com.af.tourism.pojo.vo.admin.DiaryDetailForAdminVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="content_type_name" property="contentType"/>
        <result column="visibility" property="visibility"/>
        <result column="is_top" property="isTop"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="published_at" property="publishedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.admin.DiaryAuthorForAdminVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <resultMap id="DashboardTopDiaryMap" type="com.af.tourism.pojo.vo.admin.DashboardTopDiaryVO">
        <id column="diary_id" property="diaryId"/>
        <result column="title" property="title"/>
        <result column="author_id" property="authorId"/>
        <result column="author_nickname" property="authorNickname"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
    </resultMap>

    <resultMap id="DiaryCardMap" type="com.af.tourism.pojo.vo.app.DiaryCardVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="liked" property="liked"/>
        <result column="favorited" property="favorited"/>
        <result column="published_at" property="publishedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.app.UserPublicVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <resultMap id="DiaryProfileCardMap" type="com.af.tourism.pojo.vo.app.DiaryProfileCardVO" extends="DiaryCardMap">
        <result column="is_top" property="isTop"/>
    </resultMap>

    <resultMap id="MyDiaryProfileCardMap" type="com.af.tourism.pojo.vo.app.MyDiaryProfileCardVO" extends="DiaryProfileCardMap">
        <result column="status" property="status"/>
        <result column="visibility" property="visibility"/>
    </resultMap>

    <resultMap id="DiaryDetailMap" type="com.af.tourism.pojo.vo.app.DiaryDetailVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="content" property="content"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="content_type_name" property="contentType"/>
        <result column="liked" property="liked"/>
        <result column="favorited" property="favorited"/>
        <result column="published_at" property="publishedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.app.DiaryAuthorVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
            <result column="author_bio" property="bio"/>
        </association>
    </resultMap>

    <sql id="BaseDiaryCardColumns">
        d.id,
    d.title,
    d.summary,
    d.cover_url,
    d.view_count,
    d.like_count,
    d.favorite_count,
    d.comment_count,
    d.published_at,
    0 AS liked,
    0 AS favorited,
    u.id AS author_id,
    u.nickname AS author_nickname,
    u.avatar_url AS author_avatar_url
    </sql>

    <sql id="ProfileDiaryExtraColumns">
        , d.is_top
    </sql>

    <sql id="MyProfileDiaryExtraColumns">
        , d.status
    , d.visibility
    </sql>

    <sql id="PublicDiaryConditions">
        d.status = 1
    AND d.visibility = 1
    </sql>

    <sql id="ProfileDiaryOrderBy">
        <choose>
            <when test="queryDTO.sortCode == 'hot'">
                ORDER BY d.like_count DESC, d.published_at DESC, d.id DESC
            </when>
            <otherwise>
                ORDER BY d.is_top DESC, d.published_at DESC, d.id DESC
            </otherwise>
        </choose>
    </sql>

    <sql id="CommonDiaryOrderBy">
        <choose>
            <when test="queryDTO.sortCode == 'hot'">
                ORDER BY d.like_count DESC, d.published_at DESC, d.id DESC
            </when>
            <otherwise>
                ORDER BY d.published_at DESC, d.id DESC
            </otherwise>
        </choose>
    </sql>

    <select id="selectMyDiaryProfileList" resultMap="MyDiaryProfileCardMap">
        SELECT
        <include refid="BaseDiaryCardColumns"/>
        <include refid="ProfileDiaryExtraColumns"/>
        <include refid="MyProfileDiaryExtraColumns"/>
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE d.user_id = #{userId}
        <include refid="ProfileDiaryOrderBy"/>
    </select>

    <select id="selectUserDiaryProfileList" resultMap="DiaryProfileCardMap">
        SELECT
        <include refid="BaseDiaryCardColumns"/>
        <include refid="ProfileDiaryExtraColumns"/>
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE d.user_id = #{userId}
        AND <include refid="PublicDiaryConditions"/>
        <include refid="ProfileDiaryOrderBy"/>
    </select>

    <select id="selectMoreDiariesByAuthor" resultMap="DiaryCardMap">
        SELECT
        <include refid="BaseDiaryCardColumns"/>
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE d.user_id = #{userId}
        AND <include refid="PublicDiaryConditions"/>
        AND d.id != #{excludeDiaryId}
        <include refid="CommonDiaryOrderBy"/>
    </select>

    <select id="selectDiaryList" resultMap="DiaryCardMap">
        SELECT
        <include refid="BaseDiaryCardColumns"/>
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE <include refid="PublicDiaryConditions"/>
        <include refid="CommonDiaryOrderBy"/>
    </select>

    <select id="selectDiaryDetail" resultMap="DiaryDetailMap">
        SELECT <include refid="BaseDiaryCardColumns"/>
        , d.content
        , d.created_at
        , d.updated_at
        , u.bio AS author_bio
        , dc.name AS content_type_name
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        LEFT JOIN diary_category dc ON d.content_type = dc.id
        WHERE d.id = #{diaryId}
          AND d.status = 1
        LIMIT 1
    </select>

    <select id="selectAdminDiaryList" resultMap="AdminDiaryListMap">
        SELECT
            d.id,
            d.title,
            d.summary,
            d.cover_url,
            d.status,
            d.is_deleted,
            dc.name AS content_type_name,
            d.visibility,
            d.is_top,
            d.view_count,
            d.like_count,
            d.favorite_count,
            d.comment_count,
            d.published_at,
            d.created_at,
            d.updated_at,
            u.id AS author_id,
            u.nickname AS author_nickname
        FROM travel_diaries d
        LEFT JOIN users u ON d.user_id = u.id
        LEFT JOIN diary_category dc ON d.content_type = dc.id
        <where>
            <if test="queryDTO.keyword != null and queryDTO.keyword != ''">
                AND (
                    d.title LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                    OR d.summary LIKE CONCAT('%', #{queryDTO.keyword}, '%')
                )
            </if>
            <if test="queryDTO.authorId != null">
                AND d.user_id = #{queryDTO.authorId}
            </if>
            <if test="queryDTO.status != null">
                AND d.status = #{queryDTO.status.value}
            </if>
            <if test="queryDTO.contentType != null">
                AND d.content_type = #{queryDTO.contentType}
            </if>
            <if test="queryDTO.visibility != null">
                AND d.visibility = #{queryDTO.visibility.value}
            </if>
            <if test="queryDTO.isTop != null">
                AND d.is_top = #{queryDTO.isTop.value}
            </if>
            <if test="queryDTO.isDeleted != null">
                AND d.is_deleted = #{queryDTO.isDeleted.value}
            </if>
            <if test="queryDTO.publishedStart != null">
                AND d.published_at &gt;= #{queryDTO.publishedStart}
            </if>
            <if test="queryDTO.publishedEnd != null">
                AND d.published_at &lt;= #{queryDTO.publishedEnd}
            </if>
        </where>
        ORDER BY d.created_at DESC, d.id DESC
    </select>

    <select id="selectAdminDiaryDetail" resultMap="AdminDiaryDetailMap">
        SELECT
            d.id,
            d.title,
            d.summary,
            d.cover_url,
            d.content,
            d.status,
            d.is_deleted,
            dc.name AS content_type_name,
            d.visibility,
            d.is_top,
            d.view_count,
            d.like_count,
            d.favorite_count,
            d.comment_count,
            d.published_at,
            d.created_at,
            d.updated_at,
            u.id AS author_id,
            u.nickname AS author_nickname
        FROM travel_diaries d
        LEFT JOIN users u ON d.user_id = u.id
        LEFT JOIN diary_category dc ON d.content_type = dc.id
        WHERE d.id = #{diaryId}
        LIMIT 1
    </select>

    <select id="selectAdminTopDiaries" resultMap="DashboardTopDiaryMap">
        SELECT
            d.id AS diary_id,
            d.title,
            d.user_id AS author_id,
            u.nickname AS author_nickname,
            d.cover_url,
            d.view_count,
            d.like_count,
            d.favorite_count,
            d.comment_count
        FROM travel_diaries d
        LEFT JOIN users u ON d.user_id = u.id
        WHERE d.status = 1
          AND d.is_deleted = 0
          AND d.published_at &gt;= #{startTime}
          AND d.published_at &lt; #{endTime}
        ORDER BY (
            COALESCE(d.view_count, 0)
            + COALESCE(d.like_count, 0) * 5
            + COALESCE(d.favorite_count, 0) * 8
            + COALESCE(d.comment_count, 0) * 6
        ) DESC,
        d.published_at DESC,
        d.id DESC
        LIMIT #{limit}
    </select>

    <update id="updateCommentCount">
        UPDATE travel_diaries
        SET comment_count = IF(comment_count + #{delta} &lt; 0, 0, comment_count + #{delta})
        WHERE id = #{diaryId}
    </update>

    <update id="updateLikeCount">
        UPDATE travel_diaries
        SET like_count = IF(like_count + #{delta} &lt; 0, 0, like_count + #{delta})
        WHERE id = #{diaryId}
    </update>

    <update id="updateFavoriteCount">
        UPDATE travel_diaries
        SET favorite_count = IF(favorite_count + #{delta} &lt; 0, 0, favorite_count + #{delta})
        WHERE id = #{diaryId}
    </update>
</mapper>

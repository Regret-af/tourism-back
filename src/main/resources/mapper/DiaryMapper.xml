<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.DiaryMapper">

    <resultMap id="DiaryCardMap" type="com.af.tourism.pojo.vo.DiaryCardVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="liked" property="liked"/>
        <result column="favorited" property="favorited"/>
        <result column="published_at" property="publishedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.UserPublicVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <resultMap id="DiaryDetailMap" type="com.af.tourism.pojo.vo.DiaryDetailVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="content" property="content"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="favorite_count" property="favoriteCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="liked" property="liked"/>
        <result column="favorited" property="favorited"/>
        <result column="published_at" property="publishedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <association property="author" javaType="com.af.tourism.pojo.vo.UserPublicVO">
            <id column="author_id" property="id"/>
            <result column="author_nickname" property="nickname"/>
            <result column="author_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <select id="selectDiaryList" resultMap="DiaryCardMap">
        SELECT
            d.id,
            d.title,
            d.summary,
            d.cover_url,
            d.view_count,
            d.like_count,
            d.favorite_count,
            d.comment_count,
            d.published_at,
            0 AS liked,
            0 AS favorited,
            u.id AS author_id,
            u.nickname AS author_nickname,
            u.avatar_url AS author_avatar_url
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE d.status = 1
        <choose>
            <when test="queryDTO.sort == 'hot'">
                ORDER BY d.like_count DESC, d.published_at DESC, d.id DESC
            </when>
            <otherwise>
                ORDER BY d.published_at DESC, d.id DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectDiaryDetail" resultMap="DiaryDetailMap">
        SELECT
            d.id,
            d.title,
            d.summary,
            d.cover_url,
            d.content,
            d.view_count,
            d.like_count,
            d.favorite_count,
            d.comment_count,
            d.published_at,
            d.created_at,
            d.updated_at,
            0 AS liked,
            0 AS favorited,
            u.id AS author_id,
            u.nickname AS author_nickname,
            u.avatar_url AS author_avatar_url
        FROM travel_diaries d
        INNER JOIN users u ON d.user_id = u.id
        WHERE d.id = #{diaryId}
          AND d.status = 1
        LIMIT 1
    </select>

    <update id="updateCommentCount">
        UPDATE travel_diaries
        SET comment_count = IF(comment_count + #{delta} &lt; 0, 0, comment_count + #{delta})
        WHERE id = #{diaryId}
    </update>

    <update id="updateLikeCount">
        UPDATE travel_diaries
        SET like_count = IF(like_count + #{delta} &lt; 0, 0, like_count + #{delta})
        WHERE id = #{diaryId}
    </update>

    <update id="updateFavoriteCount">
        UPDATE travel_diaries
        SET favorite_count = IF(favorite_count + #{delta} &lt; 0, 0, favorite_count + #{delta})
        WHERE id = #{diaryId}
    </update>
</mapper>

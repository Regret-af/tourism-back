<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.NotificationMapper">

    <resultMap id="NotificationVOMap" type="com.af.tourism.pojo.vo.NotificationVO">
        <id column="id" property="id"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="related_diary_id" property="relatedDiaryId"/>
        <result column="related_comment_id" property="relatedCommentId"/>
        <result column="is_read" property="isRead"/>
        <result column="read_time" property="readTime"/>
        <result column="created_at" property="createdAt"/>
        <association property="sender" javaType="com.af.tourism.pojo.vo.UserPublicVO">
            <id column="sender_id" property="id"/>
            <result column="sender_nickname" property="nickname"/>
            <result column="sender_avatar_url" property="avatarUrl"/>
        </association>
    </resultMap>

    <select id="selectNotificationPage" resultMap="NotificationVOMap">
        SELECT n.id,
               n.type,
               n.title,
               n.content,
               n.related_diary_id,
               n.related_comment_id,
               n.is_read,
               n.read_time,
               n.created_at,
               s.id AS sender_id,
               s.nickname AS sender_nickname,
               s.avatar_url AS sender_avatar_url
        FROM notifications n
        LEFT JOIN users s ON n.sender_user_id = s.id
        <where>
            n.recipient_user_id = #{recipientUserId}
            <if test="queryDTO.isRead != null">
                AND n.is_read = #{queryDTO.isRead}
            </if>
            <if test="queryDTO.type != null">
                AND n.type = #{queryDTO.type}
            </if>
        </where>
        ORDER BY n.created_at DESC, n.id DESC
    </select>

    <select id="countUnreadByRecipientUserId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM notifications
        WHERE recipient_user_id = #{recipientUserId}
          AND is_read = 0
    </select>

    <update id="markAsRead">
        UPDATE notifications
        SET is_read = 1,
            read_time = #{readTime}
        WHERE id = #{notificationId}
          AND recipient_user_id = #{recipientUserId}
          AND is_read = 0
    </update>
</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.af.tourism.mapper.UserRoleMapper">

    <select id="selectByUserIdAndRoleId" resultType="com.af.tourism.pojo.entity.UserRole">
        SELECT id,
               user_id,
               role_id,
               created_at
        FROM user_roles
        WHERE user_id = #{userId}
          AND role_id = #{roleId}
        LIMIT 1
    </select>

</mapper>
